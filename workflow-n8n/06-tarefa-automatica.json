{
  "name": "06 - Tarefa Automática por Eventos",
  "description": "Cria tarefas automaticamente quando certos eventos acontecem: proposta enviada → agendar follow-up, venda fechada → agendar pós-venda.",
  "nodes": [
    {
      "name": "Webhook - Oportunidade Atualizada",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "httpMethod": "POST",
        "path": "opportunity-updated",
        "responseMode": "onReceived"
      },
      "notes": "Configure Database Webhook no Supabase para UPDATE na tabela opportunities."
    },
    {
      "name": "Verificar Etapa",
      "type": "n8n-nodes-base.switch",
      "parameters": {
        "rules": {
          "string": [
            { "value1": "={{$json.record.stage}}", "value2": "proposta_enviada" },
            { "value1": "={{$json.record.stage}}", "value2": "venda_fechada" },
            { "value1": "={{$json.record.stage}}", "value2": "perdido" }
          ]
        }
      }
    },
    {
      "name": "Tarefa - Follow-up Proposta",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/tasks",
        "headers": {
          "apikey": "={{$env.SUPABASE_SERVICE_KEY}}",
          "Authorization": "Bearer {{$env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Follow-up da proposta enviada",
          "description": "Proposta enviada para o cliente. Ligar em 2 dias para saber se tem dúvidas.",
          "client_id": "={{$json.record.client_id}}",
          "tenant_id": "={{$json.record.tenant_id}}",
          "responsible_id": "={{$json.record.responsible_id}}",
          "status": "pendente",
          "due_date": "={{$now.plus(2,'days').toISO()}}"
        }
      },
      "notes": "Quando proposta é enviada → cria tarefa de follow-up em 2 dias."
    },
    {
      "name": "Tarefa - Pós-Venda",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/tasks",
        "headers": {
          "apikey": "={{$env.SUPABASE_SERVICE_KEY}}",
          "Authorization": "Bearer {{$env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Pós-venda: verificar satisfação",
          "description": "Venda fechada! Ligar em 7 dias para verificar satisfação e pedir indicação.",
          "client_id": "={{$json.record.client_id}}",
          "tenant_id": "={{$json.record.tenant_id}}",
          "responsible_id": "={{$json.record.responsible_id}}",
          "status": "pendente",
          "due_date": "={{$now.plus(7,'days').toISO()}}"
        }
      },
      "notes": "Quando venda é fechada → cria tarefa de pós-venda em 7 dias."
    },
    {
      "name": "Registrar Motivo Perda",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/activities",
        "headers": {
          "apikey": "={{$env.SUPABASE_SERVICE_KEY}}",
          "Authorization": "Bearer {{$env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "type": "deal_lost",
          "description": "Oportunidade perdida. Motivo: {{$json.record.loss_reason}}. Notas: {{$json.record.loss_notes}}",
          "client_id": "={{$json.record.client_id}}",
          "tenant_id": "={{$json.record.tenant_id}}",
          "user_id": "={{$json.record.responsible_id}}"
        }
      },
      "notes": "Quando deal é perdido → registra atividade com motivo."
    }
  ]
}
