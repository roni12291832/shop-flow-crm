{
  "name": "02 - WhatsApp Send Message",
  "description": "Envia mensagens do CRM para o WhatsApp do cliente. Ativado via webhook quando o atendente envia mensagem pelo CRM.",
  "nodes": [
    {
      "name": "Webhook Enviar Mensagem",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-send",
        "responseMode": "onReceived"
      },
      "notes": "Recebe do CRM: { phone, message, client_id, tenant_id, user_id }"
    },
    {
      "name": "Enviar via WhatsApp API",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.WHATSAPP_API_URL}}/message/sendText/default",
        "headers": {
          "apikey": "={{$env.WHATSAPP_API_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "number": "={{$json.phone}}@s.whatsapp.net",
          "text": "={{$json.message}}"
        }
      },
      "notes": "Envia a mensagem via Evolution API. Adapte o endpoint conforme sua API (Z-API, Baileys, etc)."
    },
    {
      "name": "Registrar Atividade",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/activities",
        "headers": {
          "apikey": "={{$env.SUPABASE_SERVICE_KEY}}",
          "Authorization": "Bearer {{$env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "type": "whatsapp_message_sent",
          "description": "={{$json.message}}",
          "client_id": "={{$json.client_id}}",
          "tenant_id": "={{$json.tenant_id}}",
          "user_id": "={{$json.user_id}}"
        }
      },
      "notes": "Registra a mensagem enviada como atividade no histórico do cliente."
    }
  ]
}
